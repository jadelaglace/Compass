#!/usr/bin/env python3
"""
Compass CLI — OpenClaw Skill entry point.

Usage:
    compass <action> [key=value ...]

Actions:
    search   Full-text search across entities
    top      Top-scored entities (optional category filter)
    get      Single entity by ID (includes refs)
    feed     Daily digest (top inbox + recent + strategic)
    context  Agent context injection
    create   Create new entity
    score    Update entity scores
    access   Record access (triggers score boost)

Environment:
    COMPASS_API_URL  API base URL (default: http://localhost:8080)
"""

import sys
import os
import json
import argparse
import urllib.request
import urllib.error
import urllib.parse

# Windows 控制台默认 GBK，emoji(✅⭐)会 UnicodeEncodeError；强制 stdout/stderr UTF-8
if hasattr(sys.stdout, "reconfigure"):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
if hasattr(sys.stderr, "reconfigure"):
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")


def get_api_url() -> str:
    return os.environ.get("COMPASS_API_URL", "http://localhost:8080")


def api_url(path: str) -> str:
    return f"{get_api_url().rstrip('/')}/{path.lstrip('/')}"


def http_get(path: str, params: dict | None = None) -> dict:
    url = api_url(path)
    if params:
        url += "?" + urllib.parse.urlencode(params)
    req = urllib.request.Request(url)
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        try:
            err_body = json.loads(body)
            print(json.dumps({"error": err_body.get("error", body), "status": e.code}), file=sys.stderr)
        except Exception:
            print(json.dumps({"error": body or e.reason, "status": e.code}), file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(json.dumps({"error": f"connection refused — is compass-api running? ({e.reason})"}), file=sys.stderr)
        sys.exit(1)


def http_patch(path: str, data: dict) -> dict:
    url = api_url(path)
    body_bytes = json.dumps(data).encode()
    req = urllib.request.Request(url, data=body_bytes, method="PATCH")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        try:
            err_body = json.loads(body)
            print(json.dumps({"error": err_body.get("error", body), "status": e.code}), file=sys.stderr)
        except Exception:
            print(json.dumps({"error": body or e.reason, "status": e.code}), file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(json.dumps({"error": f"connection refused — is compass-api running? ({e.reason})"}), file=sys.stderr)
        sys.exit(1)


def http_post(path: str, data: dict) -> dict:
    url = api_url(path)
    body_bytes = json.dumps(data).encode()
    req = urllib.request.Request(url, data=body_bytes)
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        try:
            err_body = json.loads(body)
            print(json.dumps({"error": err_body.get("error", body), "status": e.code}), file=sys.stderr)
        except Exception:
            print(json.dumps({"error": body or e.reason, "status": e.code}), file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(json.dumps({"error": f"connection refused — is compass-api running? ({e.reason})"}), file=sys.stderr)
        sys.exit(1)


def http_post_empty(path: str) -> dict:
    return http_post(path, {})


def parse_keyval(args: list[str]) -> dict:
    """Parse key=value arguments into a dict."""
    result = {}
    for arg in args:
        if "=" in arg:
            key, val = arg.split("=", 1)
            result[key.strip()] = val.strip()
    return result


# ---- Actions ----


def action_search(params: dict) -> None:
    q = params.get("q", "")
    limit = int(params.get("limit", 20))
    result = http_get("/search", {"q": q, "limit": limit})
    print(json.dumps(result, indent=2))


def action_top(params: dict) -> None:
    limit = int(params.get("limit", 20))
    layer = params.get("layer") or params.get("category") or None
    result = http_get("/entities/top", {"limit": limit, **(({"layer": layer}) if layer else {})})
    print(json.dumps(result, indent=2))


def action_get(params: dict) -> None:
    entity_id = params.get("id")
    if not entity_id:
        print(json.dumps({"error": "id is required"}), file=sys.stderr)
        sys.exit(1)
    result = http_get(f"/entities/{entity_id}")
    print(json.dumps(result, indent=2))


def action_feed(params: dict) -> None:
    limit = int(params.get("limit", 10))
    mode = params.get("mode", "explore")
    result = http_get("/feed", {"limit": limit, "mode": mode})
    print(json.dumps(result, indent=2))


def action_context(params: dict) -> None:
    task = params.get("task")
    if not task:
        print(json.dumps({"error": "task is required"}), file=sys.stderr)
        sys.exit(1)
    top_k = int(params.get("top_k", 5))
    result = http_post("/agent/context", {"task": task, "top_k": top_k})
    print(json.dumps(result, indent=2))


def action_create(params: dict) -> None:
    if not params.get("title"):
        print(json.dumps({"error": "title is required"}), file=sys.stderr)
        sys.exit(1)

    data: dict = {
        "title": params["title"],
        "layer": params.get("layer", "knowledge"),
    }
    for dim in ("interest", "strategy", "consensus"):
        if dim in params:
            data[dim] = float(params[dim])
    if params.get("content"):
        data["content"] = params["content"]
    result = http_post("/entities", data)
    print(json.dumps(result, indent=2))


def action_score(params: dict) -> None:
    entity_id = params.get("id")
    if not entity_id:
        print(json.dumps({"error": "id is required"}), file=sys.stderr)
        sys.exit(1)

    data = {}
    for dim in ("interest", "strategy", "consensus"):
        if dim in params:
            data[dim] = float(params[dim])

    result = http_patch(f"/entities/{entity_id}/score", data)
    print(json.dumps(result, indent=2))


def action_access(params: dict) -> None:
    entity_id = params.get("id")
    if not entity_id:
        print(json.dumps({"error": "id is required"}), file=sys.stderr)
        sys.exit(1)

    depth = params.get("depth", "read")
    result = http_patch(f"/entities/{entity_id}/access", {"depth": depth})
    print(json.dumps(result, indent=2))


def _required_param(params: dict, name: str) -> str:
    value = params.get(name, "").strip()
    if not value:
        print(json.dumps({"error": f"{name} is required"}), file=sys.stderr)
        sys.exit(1)
    return value


def _suggestion_id(params: dict) -> str:
    return params.get("suggestion_id", params.get("id", "")).strip()


def action_tag_suggestions(params: dict) -> None:
    entity_id = _required_param(params, "id")
    payload = {}
    if params.get("candidates"):
        try:
            candidates = json.loads(params["candidates"])
        except json.JSONDecodeError as e:
            print(json.dumps({"error": f"invalid candidates JSON: {e}"}), file=sys.stderr)
            sys.exit(1)
        if not isinstance(candidates, list):
            print(json.dumps({"error": "candidates must be a JSON array"}), file=sys.stderr)
            sys.exit(1)
        payload["candidates"] = candidates
    result = http_post(f"/entities/{urllib.parse.quote(entity_id, safe='')}/tag-suggestions", payload)
    print(json.dumps(result, indent=2, ensure_ascii=False))


def action_related(params: dict) -> None:
    entity_id = _required_param(params, "id")
    limit = int(params.get("limit", 10))
    result = http_get(
        f"/entities/{urllib.parse.quote(entity_id, safe='')}/related",
        {"limit": limit},
    )
    print(json.dumps(result, indent=2, ensure_ascii=False))


def action_suggestion_transition(params: dict, kind: str, transition: str) -> None:
    suggestion_id = _suggestion_id(params)
    if not suggestion_id:
        print(json.dumps({"error": "suggestion_id is required"}), file=sys.stderr)
        sys.exit(1)
    result = http_post_empty(
        f"/{kind}-suggestions/{urllib.parse.quote(suggestion_id, safe='')}/{transition}"
    )
    print(json.dumps(result, indent=2, ensure_ascii=False))


def action_accept_tag(params: dict) -> None:
    action_suggestion_transition(params, "tag", "accept")


def action_reject_tag(params: dict) -> None:
    action_suggestion_transition(params, "tag", "reject")


def action_accept_related(params: dict) -> None:
    action_suggestion_transition(params, "related", "accept")


def action_reject_related(params: dict) -> None:
    action_suggestion_transition(params, "related", "reject")


def action_weekly(params: dict) -> None:
    query = {
        "from": _required_param(params, "from"),
        "to": _required_param(params, "to"),
        "tz": _required_param(params, "tz"),
    }
    result = http_get("/reports/weekly", query)
    print(json.dumps(result, indent=2, ensure_ascii=False))


def _render_search(data) -> str:
    # API 返回列表；旧格式也兼容 {results: [...]}
    results = data if isinstance(data, list) else data.get("results", [])
    if not results:
        return "没有找到相关结果。"
    lines = ["## 搜索结果"]
    for i, ent in enumerate(results, 1):
        score = ent.get("composite", 0) or 0
        title = ent.get("title") or ent.get("id", "?")
        eid = ent.get("id", "")
        layer = ent.get("layer", "")
        snippet = ent.get("snippet", "")
        line = f"{i}. [{title}]({eid}) — ⭐{score:.1f}分"
        if layer:
            line += f" [{layer}]"
        if snippet:
            line += f"\n   {snippet}"
        lines.append(line)
    return "\n".join(lines)


def _render_top(data) -> str:
    # API 返回列表；旧格式也兼容 {results: [...]}
    results = data if isinstance(data, list) else data.get("results", [])
    if not results:
        return "没有找到结果。"
    lines = [f"## Top {len(results)}"]
    for i, ent in enumerate(results, 1):
        score = ent.get("composite", 0) or 0
        title = ent.get("title") or ent.get("id", "?")
        eid = ent.get("id", "")
        layer = ent.get("layer", "")
        line = f"{i}. [{title}]({eid}) — ⭐{score:.1f}分"
        if layer:
            line += f" [{layer}]"
        lines.append(line)
    return "\n".join(lines)


def _render_get(data: dict) -> str:
    title = data.get("title", "?")
    eid = data.get("id", "?")
    layer = data.get("layer", "?")
    status = data.get("status", "")
    # API 返回 score 对象（interest/strategy/consensus/composite/...）
    score = data.get("score") or {}
    interest = score.get("interest", 0) or 0
    strategy = score.get("strategy", 0) or 0
    consensus = score.get("consensus", 0) or 0
    final = score.get("composite", data.get("composite", 0)) or 0

    refs = data.get("refs", [])

    parts = [f"## {title} ({eid})"]
    if layer:
        parts.append(f"分类：{layer}")
    if status:
        parts.append(f"状态：{status}")
    parts.append(f"⭐ 评分：{final:.1f}（interest {interest:.1f} / strategy {strategy:.1f} / consensus {consensus:.1f}）")

    if refs:
        refs_str = ", ".join(f"[[{r}]]" for r in refs)
        parts.append(f"→ 引用：{refs_str}")

    return "\n".join(parts)


def _render_feed(data) -> str:
    # API /feed 返回单一列表；旧格式也兼容 {top_inbox/recently_updated/strategic}
    if isinstance(data, list):
        top_inbox = data[:3]
        recently_updated = []
        strategic = []
    else:
        top_inbox = data.get("top_inbox", [])[:3]
        recently_updated = data.get("recently_updated", [])[:3]
        strategic = data.get("strategic", [])[:3]

    lines = ["**今日焦点**"]
    for ent in top_inbox:
        title = ent.get("title") or ent.get("id", "?")
        eid = ent.get("id", "?")
        score = ent.get("composite", 0) or 0
        lines.append(f"- [{title}]({eid}) — ⭐{score:.1f}")

    if recently_updated:
        lines.append("**最近更新**")
        for ent in recently_updated:
            title = ent.get("title") or ent.get("id", "?")
            eid = ent.get("id", "?")
            score = ent.get("composite", 0) or 0
            lines.append(f"- [{title}]({eid}) — ⭐{score:.1f}")

    if strategic:
        lines.append("**战略焦点**")
        for ent in strategic:
            title = ent.get("title") or ent.get("id", "?")
            eid = ent.get("id", "?")
            score = ent.get("composite", 0) or 0
            lines.append(f"- [{title}]({eid}) — ⭐{score:.1f}")

    return "\n".join(lines)


def _render_context(data: dict) -> str:
    ctx = data.get("context", [])
    if not ctx:
        return "没有找到相关上下文。"
    lines = ["## 上下文"]
    for ent in ctx:
        title = ent.get("title", "?")
        eid = ent.get("id", "?")
        summary = ent.get("content", "")[:100]
        score = ent.get("composite", 0)
        lines.append(f"- [{title}]({eid})：{summary}... ⭐{score:.1f}")
    reasoning = data.get("reasoning", "")
    if reasoning:
        lines.append(f"\n推理：{reasoning}")
    return "\n".join(lines)


def _render_create(data: dict) -> str:
    title = data.get("title", "?")
    eid = data.get("id", "?")
    return f"✅ 已创建：[{title}]({eid})"


def _render_score(data: dict) -> str:
    eid = data.get("id", "?")
    s = data.get("score") or {}
    composite = s.get("composite", data.get("composite", 0))
    return f"✅ 评分已更新：[{eid}]({eid}) - ⭐{composite:.1f}"


def _render_access(data: dict) -> str:
    eid = data.get("id", "?")
    s = data.get("score") or {}
    composite = s.get("composite", data.get("composite", 0))
    return f"✅ 访问已记录：[{eid}]({eid}) - ⭐{composite:.1f}"


def _render_tag_suggestions(data: dict) -> str:
    suggestions = data.get("suggestions", [])
    if not suggestions:
        return "没有标签建议。"
    lines = ["## 标签建议"]
    for suggestion in suggestions:
        tag = suggestion.get("tag", "?")
        confidence = suggestion.get("confidence", 0) or 0
        status = suggestion.get("status", "pending")
        reason = suggestion.get("reason", "")
        line = f"- #{tag} — 置信度 {confidence:.2f}（{status}）"
        if reason:
            line += f"：{reason}"
        lines.append(line)
    return "\n".join(lines)


def _render_related(data: dict) -> str:
    suggestions = data.get("suggestions", [])
    if not suggestions:
        return "没有关联推荐。"
    lines = ["## 关联推荐"]
    for suggestion in suggestions:
        title = suggestion.get("title") or suggestion.get("id", "?")
        entity_id = suggestion.get("id", "?")
        score = suggestion.get("score", 0) or 0
        status = suggestion.get("status", "pending")
        reasons = "; ".join(suggestion.get("reasons", []))
        line = f"- [{title}]({entity_id}) — 推荐分 {score:.3f}（{status}）"
        if reasons:
            line += f"：{reasons}"
        lines.append(line)
    return "\n".join(lines)


def _render_suggestion_transition(data: dict, kind: str, transition: str) -> str:
    status = data.get("status", "unknown")
    if kind == "tag":
        subject = f"#{data.get('tag', '?')}"
    else:
        subject = data.get("title") or data.get("id", "?")
    verb = "已接受" if transition == "accept" else "已拒绝"
    if status == "expired":
        return f"建议已过期，未写回：{subject}。"
    if status == "rejected":
        return f"建议已拒绝：{subject}。"
    if status == "accepted":
        return f"建议已接受：{subject}。"
    return f"建议{verb}：{subject}（状态：{status}）。"


def _render_weekly(data: dict) -> str:
    lines = [f"## 周报 {data.get('from', '?')} 至 {data.get('to', '?')}（{data.get('tz', '?')}）"]
    quality = data.get("data_quality") or {}
    if quality.get("history_unavailable"):
        missing = ", ".join(quality.get("missing", [])) or "history"
        lines.append(f"数据提示：历史数据不可用（缺失：{missing}）。")
    lines.append(f"评分变化：{len(data.get('score_changes', []))} 个实体")
    lines.append(f"访问 {data.get('access_count', 0)} 次，复习 {data.get('review_count', 0)} 次")
    access = data.get("access_stats") or {}
    if access:
        lines.append(
            "访问明细："
            f"glance {access.get('glance', 0)} / read {access.get('read', 0)} / "
            f"study {access.get('study', 0)} / apply {access.get('apply', 0)}"
        )
    new_entities = data.get("new_entities", [])
    if new_entities:
        lines.append("新增实体：" + ", ".join(new_entities))
    stats = data.get("suggestion_stats") or {}
    lines.append(
        "建议处理："
        f"接受 {stats.get('accepted', 0)} / 拒绝 {stats.get('rejected', 0)} / "
        f"过期 {stats.get('expired', 0)}"
    )
    return "\n".join(lines)


def action_render(params: dict) -> None:
    raw = params.get("raw")
    action_name = params.get("action")
    # 优先 raw= 参数；未提供则从 stdin 读（支持管道，#159）
    if not raw and not sys.stdin.isatty():
        raw = sys.stdin.read()
    if not raw:
        print(json.dumps({"error": "raw is required (via raw= arg or stdin)"}), file=sys.stderr)
        sys.exit(1)
    if not action_name:
        print(json.dumps({"error": "action is required"}), file=sys.stderr)
        sys.exit(1)

    # 容忍前导 UTF-8 BOM（stdin 来自部分 shell/管道时会带 BOM）
    raw = raw.lstrip("\ufeff")
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"invalid JSON: {e}"}), file=sys.stderr)
        sys.exit(1)

    renderers = {
        "search": _render_search,
        "top": _render_top,
        "get": _render_get,
        "feed": _render_feed,
        "context": _render_context,
        "create": _render_create,
        "score": _render_score,
        "access": _render_access,
        "tag_suggestions": _render_tag_suggestions,
        "tags": _render_tag_suggestions,
        "related": _render_related,
        "weekly": _render_weekly,
    }

    transition_renderers = {
        "accept_tag": ("tag", "accept"),
        "reject_tag": ("tag", "reject"),
        "accept_related": ("related", "accept"),
        "reject_related": ("related", "reject"),
    }

    if action_name in transition_renderers:
        kind, transition = transition_renderers[action_name]
        print(_render_suggestion_transition(data, kind, transition))
        return
    if action_name not in renderers:
        print(json.dumps({"error": f"unknown action: {action_name}", "available": list(renderers.keys())}), file=sys.stderr)
        sys.exit(1)

    print(renderers[action_name](data))


# ---- Dispatch ----


ACTIONS = {
    "search": action_search,
    "top": action_top,
    "get": action_get,
    "feed": action_feed,
    "context": action_context,
    "create": action_create,
    "score": action_score,
    "access": action_access,
    "tag_suggestions": action_tag_suggestions,
    "tags": action_tag_suggestions,
    "related": action_related,
    "accept_tag": action_accept_tag,
    "reject_tag": action_reject_tag,
    "accept_related": action_accept_related,
    "reject_related": action_reject_related,
    "weekly": action_weekly,
    "render": action_render,
}


def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    action = sys.argv[1]
    if action not in ACTIONS:
        print(json.dumps({"error": f"unknown action: {action}", "available": list(ACTIONS.keys())}), file=sys.stderr)
        sys.exit(1)

    # Remaining args are key=value pairs
    params = parse_keyval(sys.argv[2:])
    ACTIONS[action](params)


if __name__ == "__main__":
    main()
